# Per-instance state dirs are runtime — keep only the README placeholder.
# Default hooks/settings come from claude-sandbox-shared/, not from any
# instance dir.
claude-sandbox-persistent-state-*/*
!claude-sandbox-persistent-state-*/README.md

# Shared dir is also runtime, but track the default hooks scripts so a fresh
# clone has working hooks on first launch.
claude-sandbox-shared/*
!claude-sandbox-shared/.claude/
claude-sandbox-shared/.claude/*
!claude-sandbox-shared/.claude/hooks/
!claude-sandbox-shared/.claude/hooks/**
!claude-sandbox-shared/.claude/CLAUDE.md


workspace/*
!workspace/README.md
set_working_dir.sh

# Ignore the contents of the context folder:
context_reference/*
!context_reference/README.md

SAVED_SNAPSHOTS

# Per-instance env files are user-specific. Only the template is tracked.
env.sh
env.*.sh
!env.example.sh

# Vertex-mode activation script holds a real GCP project id. Only the
# placeholder template is tracked.
SET_VERTEX_MODE.sh
!SET_VERTEX_MODE.example.sh

# Master workdir registry. Holds absolute host paths chosen by the user at
# launch time (union of env file candidates + every prior pick). Per-host
# state — regenerated by start_sandbox.sh on first run.
workdirs.txt

# Python bytecode cache. Leaks in when py_compile / pyflakes is run from
# the repo root against vertex_proxy.py.
__pycache__/

# Host-side fiss-mcp install artifacts. Only the install.sh + run-server.py
# tracked source files belong in git; the venv and cloned source tree are
# created fresh by setup_host.sh.
host_fiss_mcp/venv/
host_fiss_mcp/fiss-mcp/
