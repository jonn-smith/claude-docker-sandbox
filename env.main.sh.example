#!/usr/bin/env bash
# Example env file for the "main" instance. Copy to env.main.sh and edit paths
# to match your host layout.

export CLAUDE_SANDBOX_INSTANCE=main

# Optional: opt this instance into the shared-state layout (settings, skills,
# plugins, hooks, memory, sessions live in claude-sandbox-shared/). Default
# (unset or 0) is fully per-instance state.
#export CLAUDE_SANDBOX_USE_SHARED=1

# Optional: turn the Headroom token-compression proxy on for this instance.
#export HEADROOM=1

# Required: absolute host path to your project workspace. Bind-mounted to
# /workspace inside the container. The agent has read/write access here and
# nowhere else on the host.
export CLAUDE_SANDBOX_PROJECTS_DIR=/path/to/your/projects

# Required: absolute host path to a read-only context dir, mounted at
# /context. Use it for shared docs, schemas, prompts. Can be the same dir
# across multiple instances.
export CLAUDE_SANDBOX_CONTEXT_DIR=/path/to/your/context_reference
